	private static void loadProblem3() {
		try(Connection con=DriverManager.getConnection(url,user,pass)){
			PreparedStatement ps=con.prepareStatement("select * from problem where problem_id = ?");
			ps.setInt(1, problemId3);
			ResultSet rs=ps.executeQuery();
			
			if(rs.next()) {
				problemArea3.setText(
						"\nTitle: " + rs.getString("title")+"\n\n"+
				rs.getString("description"));
				
				expectedOutput3 =rs.getString("expected_output");
				if(expectedOutput3 != null) {
					expectedOutput3=expectedOutput3.trim();
				}else {
					expectedOutput3="";
				}
			}
			} catch(Exception e) {
				problemArea3.setText("DB Error: "+e.getMessage());
			}
	}
	
	private static  void compileRunValidate() {
		try {
			FileWriter fw=new FileWriter("Main.java");
			fw.write(codeArea3.getText());
			fw.close();
			
			
			ProcessBuilder compilePB=new ProcessBuilder("javac","Main.java");
			Process cp=compilePB.start();
			cp.waitFor();
			
			BufferedReader err=new BufferedReader(new InputStreamReader(cp.getErrorStream()));
			String line;
			if ((line = err.readLine()) != null) {
                outputArea3.setText("Compilation Error:\n" + line);
                saveResult("Compilation Error", "FAILED");  
                return;

            }
			
			ProcessBuilder runPB =
	                new ProcessBuilder("java", "Main");
	        Process rp = runPB.start();
	        
	        BufferedReader out = new BufferedReader(new InputStreamReader(rp.getInputStream()));
	        String output = "";
	        while ((line = out.readLine()) != null) {
	                    output += line;
	                }
	        
	        String status = output.trim().equals(expectedOutput3) ? "PASSED" : "FAILED";        
			
	        outputArea3.setText(
	                "\nOutput: " + output + "\n\nExpected: " +
	                expectedOutput3 + "\n\nStatus: " + status
	            );
			
			saveResult(output, status);	
		}
		catch (Exception e) {
            outputArea3.setText("Error: " + e.getMessage());
        }
		
	}
	private static void saveResult(String output, String status) {
		 try (Connection con = DriverManager.getConnection(url,user,pass)) {
	            PreparedStatement ps = con.prepareStatement(
	                    "INSERT INTO submission(problem_id,output,status) VALUES(?,?,?)"
	                );
	            ps.setInt(1, problemId3);
	            ps.setString(2, output);
	            ps.setString(3, status);
	            ps.executeUpdate();
	        }
		 catch (Exception ignored) {}
		
	}

